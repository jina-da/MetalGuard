# ============================================================
#  MetalGuard .gitignore
# ============================================================

# ------------------------------------------------------------
#  가상환경
# ------------------------------------------------------------
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.pyo

# ------------------------------------------------------------
#  모델 가중치 (용량 크므로 제외, 별도 공유)
# ------------------------------------------------------------
weights/
*.pth
*.pt
*.onnx
*.trt
*.engine

# ------------------------------------------------------------
#  학습 결과 / 시각화 이미지
# ------------------------------------------------------------
results/
*.png
*.jpg
*.jpeg
*.bmp

# ------------------------------------------------------------
#  데이터셋 (용량 크므로 제외)
# ------------------------------------------------------------
data/

# ------------------------------------------------------------
#  테스트 이미지
# ------------------------------------------------------------
test_images/

# ------------------------------------------------------------
#  로그
# ------------------------------------------------------------
*.log
logs/

# ------------------------------------------------------------
#  환경 변수 / 설정 파일
# ------------------------------------------------------------
.env
*.env
secrets.json

# ------------------------------------------------------------
#  IDE / 에디터
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ------------------------------------------------------------
#  OS
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------
#  Jupyter
# ------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# ------------------------------------------------------------
#  빌드 / 배포
# ------------------------------------------------------------
dist/
build/
*.egg-info/
